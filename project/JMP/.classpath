<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry excluding="jmp/midi/sequencer/|jmp/player/MoviePlayer.java|jmp/player/FFmpegPlayer.java" kind="src" path="source"/>
	<classpathentry combineaccessrules="false" kind="src" path="/JMPLIB"/>
	<classpathentry combineaccessrules="false" kind="src" path="/MKJMP"/>
	<classpathentry combineaccessrules="false" kind="src" path="/FFmpegWrapper"/>
	<classpathentry combineaccessrules="false" kind="src" path="/JMSynthesizer"/>
	<classpathentry combineaccessrules="false" kind="src" path="/FunctionLib_jmp"/>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="output" path="bin"/>
</classpath>
